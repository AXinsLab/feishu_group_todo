# ── Azure AI Foundry · DeepSeek-V3 ────────────────────────
# Azure AI Foundry 端点 URL，格式：https://xxx.inference.ml.azure.com/
AZURE_ENDPOINT=
# 模型部署名称，例如：deepseek-v3
AZURE_DEPLOYMENT=
# API 版本，例如：2024-05-01-preview
AZURE_API_VERSION=2024-05-01-preview
# Azure AI Foundry API Key
AZURE_API_KEY=

# ── 飞书应用配置 ──────────────────────────────────────────
# 飞书开放平台应用 App ID
FEISHU_APP_ID=
# 飞书开放平台应用 App Secret
FEISHU_APP_SECRET=
# 事件订阅验证 Token
FEISHU_VERIFICATION_TOKEN=
# 事件加密 Key（如启用加密，否则留空）
FEISHU_ENCRYPT_KEY=

# ── 飞书多维表格 ──────────────────────────────────────────
# 多维表格 App Token（首次由机器人自动创建后填入）
BITABLE_APP_TOKEN=

# ── 运维配置 ─────────────────────────────────────────────
# 系统错误告警接收会话 ID（机器人账号个人会话或运维群）
OPS_CHAT_ID=
# Scheduler Webhook 的鉴权 Secret，防止未授权触发
WEBHOOK_SECRET=

# ── 运行环境 ─────────────────────────────────────────────
# development / production
ENV=development
LOG_LEVEL=INFO
